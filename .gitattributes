# Normalize line endings: store as LF in the repo (works well for Unity + mixed OS teams)
* text=auto

# C# / shaders
*.cs text eol=lf diff=csharp
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.compute text eol=lf
*.shadergraph text eol=lf
*.shadersubgraph text eol=lf
*.raytrace text eol=lf

# Unity YAML-serialized text assets
*.meta text eol=lf
*.prefab text eol=lf
*.unity text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.overrideController text eol=lf
*.mask text eol=lf
*.brush text eol=lf
*.preset text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.rsp text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Package manifests (explicit paths)
/Packages/manifest.json text eol=lf
/Packages/packages-lock.json text eol=lf

