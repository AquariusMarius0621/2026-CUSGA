      enabled: 0
      scaleMultiplier: 1.25
      shakeMagnitude: 0.08
  - speaker: 1
    text: "\u6E05\u7406\u8005\uFF0C\u51CC\uFF0C\u7F16\u53F7Urzu7\uFF0C\u8BF7\u7ACB\u5373\u524D\u5F80\u6307\u5B9A\u706B\u529B\u70B9\uFF0C\u63A5\u7BA1\u5916\u5899\u9632\u5FA1\u5355\u5143\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 1.25
      shakeMagnitude: 0.08
  - speaker: 1
    text: "\u76EE\u6807\u5A01\u80C1\u7B49\u7EA7\uFF1A\u4F4E\u3002\u6267\u884C\u6807\u51C6\u6E05\u7406\u6D41\u7A0B\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 1.25
      shakeMagnitude: 0.08
  - speaker: 0
    text: "\u6536\u5230\uFF01\u4E3A\u4E86\u4F0A\u7538\uFF01"
    emphasis:
      enabled: 0
      scaleMultiplier: 1.25
      shakeMagnitude: 0.08
