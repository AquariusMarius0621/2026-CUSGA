  useScriptDefaultLines: 1
  dialogueId: chapter1_intro
  lines:
  - speaker: 1
    text: "\u7B2C\u4E09\u5C0F\u961F\uFF0C\u4E1C\u4FA7\u9632\u533A\u51FA\u73B0\u5C11\u91CF\u53D8\u5F02\u4F53\u3002"
