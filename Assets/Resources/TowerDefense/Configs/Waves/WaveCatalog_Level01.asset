  waves:
  - displayName: 第 01 波
    designerNote: Level 1 opening wave. Introduce basic scavengers and a short fast-wolf burst.
    spawnGroups:
    - enemyType: 1
      enemyCount: 5
      spawnInterval: 0.95
    - enemyType: 2
      enemyCount: 2
      spawnInterval: 0.55
  - displayName: 第 02 波
    designerNote: Level 1 second wave. Introduce shield support and stealth pressure.
    spawnGroups:
    - enemyType: 1
      enemyCount: 4
      spawnInterval: 0.85
    - enemyType: 3
      enemyCount: 1
      spawnInterval: 1.1
    - enemyType: 6
      enemyCount: 2
      spawnInterval: 0.8
  - displayName: 第 03 波
    designerNote: Level 1 closing wave. Mix heavy armor, repair support and one split-on-death boss.
    spawnGroups:
    - enemyType: 5
      enemyCount: 2
      spawnInterval: 1
    - enemyType: 4
      enemyCount: 1
      spawnInterval: 1.15
    - enemyType: 7
      enemyCount: 1
      spawnInterval: 1.4
