    cardIconTint: {r: 1, g: 0.78, b: 0.46, a: 1}
    cardBackgroundTint: {r: 0.16, g: 0.1, b: 0.08, a: 0.96}
    cardAccentTint: {r: 1, g: 0.62, b: 0.26, a: 1}
