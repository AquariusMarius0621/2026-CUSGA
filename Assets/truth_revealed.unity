--- !u!114 &204800002
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 204800000}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e38d2ee356d24f0d8de7b125734e4b51, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogueFontAsset: {fileID: 0}
  useScriptDefaultLines: 1
  lines:
  - speaker: 1
    text: "\u672B\u4E16\u4E8B\u4EF6\u53D1\u751F\u540E\uFF0C\u53EF\u5229\u7528\u8D44\u6E90\u9AA4\u51CF\u81F3\u65E7\u7EAA\u5143\u65F6\u671F\u7684\u7EA6\u767E\u5206\u4E4B\u4E09\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u4F0A\u7538\u5730\u533A\u5728\u7ECF\u5386\u6570\u5E74\u8D44\u6E90\u51B2\u7A81\u4E0E\u52BF\u529B\u6574\u5408\u540E\uFF0C\u5728\u539F\u5740\u4E0A\u5EFA\u7ACB\u8D77\u5C01\u95ED\u5F0F\u90FD\u5E02\u7CFB\u7EDF\u2014\u2014\u201C\u4F0A\u7538\u201D\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u4EBA\u4EEC\u9762\u4E34\u4E00\u4E2A\u65E0\u6CD5\u56DE\u907F\u7684\u95EE\u9898\uFF1A\u6709\u9650\u7684\u8D44\u6E90\uFF0C\u53EA\u80FD\u4F9B\u517B\u6709\u9650\u7684\u4EBA\u53E3\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u8C01\u8BE5\u6D3B\u4E0B\u6765\uFF1F"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u51B3\u7B56\u8005\u9009\u62E9\u4E86\u4ED6\u4EEC\u773C\u4E2D\u7684\u201C\u6700\u4F18\u89E3\u201D\u2014\u2014\u5C06\u8D44\u6E90\u4F18\u5148\u5206\u914D\u7ED9\u5BF9\u793E\u4F1A\u6700\u6709\u8D21\u732E\u7684\u4EBA\uFF1A\u5DE5\u7A0B\u5E08\u3001\u533B\u751F\u3001\u79D1\u5B66\u5BB6\u3001\u6280\u672F\u5DE5\u4EBA\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u8FD9\u4E9B\u4EBA\u80FD\u591F\u7EF4\u6301\u57CE\u5E02\u8FD0\u8F6C\uFF0C\u80FD\u591F\u7814\u53D1\u9632\u62A4\u6280\u672F\uFF0C\u80FD\u591F\u5728\u672A\u6765\u91CD\u5EFA\u6587\u660E\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u8001\u5F31\u75C5\u6B8B\uFF0C\u4EE5\u53CA\u90A3\u4E9B\u6CA1\u6709\u4E13\u4E1A\u6280\u80FD\u7684\u4EBA\uFF0C\u88AB\u7559\u5728\u4E86\u5899\u5916\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u8FD9\u4E0D\u662F\u6B8B\u5FCD\u3002\u8FD9\u662F\u5728\u6781\u7AEF\u73AF\u5883\u4E0B\uFF0C\u4E3A\u4E86\u6574\u4F53\u5B58\u7EED\u4E0D\u5F97\u4E0D\u505A\u51FA\u7684\u53D6\u820D\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u8D44\u6E90\u603B\u91CF\u6709\u9650\uFF0C\u80FD\u627F\u8F7D\u7684\u4EBA\u53E3\u4E0A\u9650\u56FA\u5B9A\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u5982\u679C\u5E73\u5747\u5206\u914D\uFF0C\u6240\u6709\u4EBA\u90FD\u53EA\u80FD\u5206\u5230\u4E0D\u8DB3\u4EE5\u62B5\u5FA1\u8F90\u5C04\u7684\u5242\u91CF\uFF0C\u6240\u6709\u4EBA\u90FD\u4F1A\u6B7B\u3002\u4F46\u5982\u679C\u96C6\u4E2D\u5206\u914D\uFF0C\u81F3\u5C11\u6709\u4E00\u90E8\u5206\u4EBA\u80FD\u6D3B\u4E0B\u6765\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u5899\u5916\u7684\u4EBA\u4E0D\u7406\u89E3\u8FD9\u79CD\u8BA1\u7B97\u3002\u5BF9\u4ED6\u4EEC\u6765\u8BF4\uFF0C\u8FD9\u53EA\u662F\u7B80\u5355\u7684\u3001\u8D64\u88F8\u88F8\u7684\u629B\u5F03\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u6240\u4EE5\u4ED6\u4EEC\u653B\u51FB\u57CE\u5899\u3002\u4ED6\u4EEC\u8981\u6D3B\u4E0B\u53BB\u3002\u8FD9\u662F\u4EBA\u7C7B\u6700\u672C\u80FD\u7684\u6C42\u751F\u53CD\u5E94\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u800C\u57CE\u5185\u7684\u4EBA\uFF0C\u4E3A\u4E86\u4FDD\u62A4\u81EA\u5DF1\uFF0C\u4E3A\u4E86\u4FDD\u62A4\u201C\u6587\u660E\u7684\u79CD\u5B50\u201D\uFF0C\u5F00\u59CB\u6740\u622E\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u51B3\u7B56\u8005\u7ED9\u6E05\u7406\u8005\u88C5\u4E0A\u8BA4\u77E5\u6EE4\u955C\uFF0C\u8BA9\u4ED6\u4EEC\u4EE5\u4E3A\u81EA\u5DF1\u5728\u6740\u602A\u7269\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u56E0\u4E3A\u5982\u679C\u6E05\u7406\u8005\u77E5\u9053\u81EA\u5DF1\u6740\u7684\u662F\u540C\u80DE\uFF0C\u6218\u540E\u521B\u4F24\u4F1A\u6467\u6BC1\u4ED6\u4EEC\u3002\u800C\u4F0A\u7538\u9700\u8981\u4ED6\u4EEC\u50CF\u673A\u5668\u4E00\u6837\u8FD0\u8F6C\uFF0C\u5FC3\u65E0\u6742\u5FF5\u5730\u6740\u654C\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u57CE\u5185\u4E0E\u57CE\u5916\u3002\u79E9\u5E8F\u4E0E\u751F\u5B58\u3002\u7406\u6027\u4E0E\u672C\u80FD\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  - speaker: 1
    text: "\u6CA1\u6709\u5BF9\u9519\u3002\u53EA\u6709\u9009\u62E9\u3002"
    emphasis:
      enabled: 0
      scaleMultiplier: 0
      shakeMagnitude: 0
  boxSize: {x: 1400, y: 220}
